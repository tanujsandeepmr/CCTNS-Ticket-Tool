@model logindemo.Models.Feedback
@{
    ViewData["Title"] = "CCTNS Feedback";
}

<div class="workspace-bg d-flex align-items-start justify-content-center min-vh-100 pt-4">
    <div class="assessment-container shadow-2xl animate__animated animate__fadeIn">

        <div class="sidebar-accent d-none d-md-flex flex-column align-items-center py-4">
            <div class="app-dot bg-primary shadow-glow mb-5"></div>
            <div class="nav-icon active"><i class="bi bi-shield-check"></i></div>
            <div class="nav-icon"><i class="bi bi-file-earmark-bar-graph"></i></div>
            <div class="nav-icon mt-auto opacity-50"><i class="bi bi-gear"></i></div>
        </div>

        <div class="content-wrapper p-4 p-md-5 position-relative">

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="success-overlay d-flex align-items-center justify-content-center">
                    <div class="success-modal p-5 text-center shadow-lg rounded-5 animate__animated animate__zoomIn">
                        <div class="success-icon-wrap mb-4">
                            <div class="check-draw"></div>
                        </div>
                        <h3 class="fw-bold text-dark mb-2">Submission Successful</h3>
                        <p class="text-muted mb-4 px-3">Thank you for providing your valuable feedback. Your assessment helps us maintain high standards of service excellence.</p>
                        <button type="button" class="btn btn-dark rounded-pill px-5" onclick="this.parentElement.parentElement.remove()">Continue</button>
                    </div>
                </div>
            }

            <div class="d-flex justify-content-between align-items-start mb-5">
                <div>
                    <h2 class="fw-black tracking-tighter text-dark mb-1">CCTNS FEEDBACK</h2>
                    <div class="d-flex align-items-center">
                        <span class="pulse-dot me-2"></span>
                        <span class="text-muted small fw-bold text-uppercase ls-1">Authorized Session • @User.Identity.Name</span>
                    </div>
                </div>
                <div class="system-tag text-primary">OFFICIAL USE ONLY</div>
            </div>

            <form asp-action="Submit" method="post" id="assessmentForm">
                @Html.AntiForgeryToken()

                <div class="row g-4 mb-5">
                    <div class="col-md-6">
                        <div class="bento-box p-4 h-100">
                            <label class="bento-label">01. Team Coordination</label>
                            <div class="rating-grid">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <input type="radio" class="btn-check" name="CooperationRating" id="coop_@i" value="@i" required>
                                    <label class="rating-square" for="coop_@i">@i</label>
                                }
                            </div>
                            <p class="x-small text-muted mt-3 mb-0">Evaluate the responsiveness and professionalism of the staff.</p>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="bento-box p-4 h-100">
                            <label class="bento-label">02. Maintenance Quality</label>
                            <div class="rating-grid">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <input type="radio" class="btn-check" name="MaintenanceRating" id="maint_@i" value="@i" required>
                                    <label class="rating-square" for="maint_@i">@i</label>
                                }
                            </div>
                            <p class="x-small text-muted mt-3 mb-0">Assess the technical resolution and work quality provided.</p>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="bento-box p-4">
                            <label class="bento-label">03. Official Observations</label>
                            <textarea class="form-control minimal-input" name="Comments" rows="3"
                                      placeholder="Please enter your formal technical remarks..." required></textarea>
                        </div>
                    </div>
                </div>

                <div class="d-flex align-items-center justify-content-between border-top pt-4">
                    <div class="d-flex flex-column">
                        <span class="text-dark fw-bold small">O&M TEAM</span>
                        <span class="text-muted x-small"> Puducherry e-Governance Society (PeGS), </span>
                        <span class="text-muted x-small"> Directorate of Information Technology, Puducherry</span>
                    </div>
                    <button type="submit" class="btn btn-dark-action px-5 py-3 shadow-lg" id="btnSubmit">
                        PROCESS SUBMISSION <i class="bi bi-send-fill ms-2"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap');

    body {
        background-color: #f1f5f9;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .fw-black {
        font-weight: 800;
    }

    .tracking-tighter {
        letter-spacing: -0.04em;
    }

    .ls-1 {
        letter-spacing: 0.1rem;
    }

    .x-small {
        font-size: 0.72rem;
    }

    .assessment-container {
        display: flex;
        background: #ffffff;
        width: 100%;
        max-width: 1000px;
        min-height: 650px;
        border-radius: 30px;
        overflow: hidden;
        border: 1px solid rgba(0,0,0,0.05);
    }

    .sidebar-accent {
        width: 85px;
        background: #0f172a;
        color: white;
    }

    .content-wrapper {
        flex: 1;
        background-image: radial-gradient(#e2e8f0 0.5px, transparent 0.5px);
        background-size: 20px 20px;
    }

    .bento-box {
        background: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(10px);
        border: 1px solid #e2e8f0;
        border-radius: 24px;
        transition: 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    }

        .bento-box:hover {
            transform: translateY(-5px);
            border-color: #2563eb;
            box-shadow: 0 20px 40px rgba(0,0,0,0.04);
        }

    .bento-label {
        font-size: 0.75rem;
        font-weight: 800;
        color: #1e293b;
        text-transform: uppercase;
        margin-bottom: 1.2rem;
        display: block;
        letter-spacing: 1px;
    }

    .rating-grid {
        display: flex;
        gap: 12px;
        justify-content: space-between;
    }

    .rating-square {
        flex: 1;
        aspect-ratio: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f8fafc;
        color: #64748b;
        border-radius: 16px;
        font-weight: 800;
        cursor: pointer;
        transition: 0.3s;
        border: 1px solid #e2e8f0;
    }

        .rating-square:hover {
            border-color: #2563eb;
            color: #2563eb;
            background: #fff;
        }

    .btn-check:checked + .rating-square {
        background: #0f172a;
        color: white;
        border-color: #0f172a;
        transform: scale(1.05);
        box-shadow: 0 10px 20px rgba(15, 23, 42, 0.2);
    }

    .minimal-input {
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        border-radius: 16px;
        font-size: 0.9rem;
        padding: 15px;
    }

        .minimal-input:focus {
            background: #fff;
            border-color: #2563eb;
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
        }

    .btn-dark-action {
        background: #0f172a;
        color: white;
        border: none;
        border-radius: 18px;
        font-weight: 700;
        transition: 0.3s;
    }

        .btn-dark-action:hover {
            background: #1e293b;
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(15, 23, 42, 0.3);
        }

    .success-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(8px);
        z-index: 100;
    }

    .success-modal {
        background: white;
        width: 80%;
        max-width: 450px;
        border: 1px solid #f1f5f9;
    }

    .success-icon-wrap {
        width: 80px;
        height: 80px;
        background: #dcfce7;
        border-radius: 50%;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .check-draw {
        width: 30px;
        height: 15px;
        border-left: 5px solid #16a34a;
        border-bottom: 5px solid #16a34a;
        transform: rotate(-45deg);
        margin-top: -5px;
    }

    .app-dot {
        width: 14px;
        height: 14px;
        border-radius: 50%;
    }

    .shadow-glow {
        box-shadow: 0 0 20px #2563eb;
    }

    .nav-icon {
        font-size: 1.5rem;
        color: #475569;
        margin-bottom: 35px;
        cursor: pointer;
        transition: 0.3s;
    }

        .nav-icon:hover {
            color: white;
        }

        .nav-icon.active {
            color: white;
            border-left: 3px solid #2563eb;
            padding-left: 5px;
        }

    .system-tag {
        font-weight: 800;
        font-size: 0.65rem;
        background: #eff6ff;
        padding: 5px 12px;
        border-radius: 100px;
        letter-spacing: 1px;
    }

    .pulse-dot {
        width: 8px;
        height: 8px;
        background: #22c55e;
        border-radius: 50%;
        box-shadow: 0 0 10px #22c55e;
    }
</style>

<script>
    document.getElementById('assessmentForm').onsubmit = function() {
        var btn = document.getElementById('btnSubmit');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> PROCESSING...';
    };
</script>