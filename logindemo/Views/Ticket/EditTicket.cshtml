@model logindemo.Models.Ticket

@{
    ViewData["Title"] = "Official Edit Portal";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">

<style>
    :root {
        --gov-navy: #001529;
        --gov-blue: #003a8c;
        --input-focus: #e6f7ff;
    }

    /* 🎯 CENTER ENGINE */
    html, body {
        height: 100%;
        margin: 0;
    }

    body {
        background: #f0f2f5 url('https://www.transparenttextures.com/patterns/cubes.png');
        font-family: 'Plus Jakarta Sans', sans-serif;
        display: flex;
        flex-direction: column;
    }

    .main-viewport {
        display: flex;
        flex: 1;
        align-items: center; /* Vertical Center */
        justify-content: center; /* Horizontal Center */
        padding: 40px 20px;
    }

    .content-container {
        width: 100%;
        max-width: 850px;
        animation: cardSlideUp 0.5s ease-out;
    }

    @@keyframes cardSlideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* 🏛️ MODERN CARD DESIGN */
    .edit-card {
        background: white;
        border-radius: 24px;
        box-shadow: 0 20px 50px rgba(0, 21, 41, 0.1);
        border: 1px solid rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .card-header-gradient {
        background: linear-gradient(135deg, var(--gov-navy), var(--gov-blue));
        padding: 30px;
        color: white;
        text-align: center;
    }

    .form-body {
        padding: 40px;
    }

    /* FORM STYLING */
    .form-label {
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: black;
        margin-bottom: 8px;
    }

    .form-control, .form-select {
        border-radius: 12px;
        padding: 12px 16px;
        border: 2px solid #f1f5f9;
        background-color: #f8fafc;
        font-weight: 500;
        transition: all 0.2s;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--gov-blue);
            background-color: white;
            box-shadow: 0 0 0 4px rgba(0, 58, 140, 0.1);
        }

    .bg-readonly {
        background-color: #f1f5f9 !important;
        border-color: #e2e8f0 !important;
        color: #94a3b8;
        cursor: not-allowed;
        font-weight: 600;
    }

    .required-star {
        color: #ef4444;
        margin-left: 2px;
    }

    .btn-update {
        background: var(--gov-blue);
        color: white;
        border: none;
        padding: 14px;
        border-radius: 14px;
        font-weight: 800;
        letter-spacing: 1px;
        transition: all 0.3s;
    }

        .btn-update:hover {
            background: var(--gov-navy);
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 58, 140, 0.3);
        }

    .btn-cancel {
        border: 2px solid #e2e8f0;
        padding: 14px;
        border-radius: 14px;
        font-weight: 700;
        color: #64748b;
        transition: all 0.2s;
    }

        .btn-cancel:hover {
            background: #f1f5f9;
            color: #1e293b;
        }
</style>

<div class="main-viewport">
    <div class="content-container">

        <div class="edit-card">
            <div class="card-header-gradient">
                <div class="d-flex justify-content-center align-items-center mb-2">
                    <i class="bi bi-pencil-square fs-3 me-3"></i>
                    <h2 class="mb-0 fw-800">Edit Ticket Detail</h2>
                </div>
                <p class="opacity-75 mb-0 small text-uppercase fw-bold" style="letter-spacing: 2px;">CCTNS Official Record Modification</p>
            </div>

            <div class="form-body">
                <form asp-action="EditTicket" method="post" id="editTicketForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Status" />

                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label">System Ticket ID</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0" style="border-radius: 12px 0 0 12px;"><i class="bi bi-hash text-muted"></i></span>
                                <input asp-for="TicketId" class="form-control bg-readonly border-start-0" readonly />
                            </div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Reported Date</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0" style="border-radius: 12px 0 0 12px;"><i class="bi bi-calendar-event text-muted"></i></span>
                                <input class="form-control bg-readonly border-start-0" value="@Model.CreatedAt.ToString("MMM dd, yyyy")" readonly />
                            </div>
                        </div>

                        <div class="col-12">
                            <label asp-for="ReporterName" class="form-label">Reporter Full Name <span class="required-star">*</span></label>
                            <input asp-for="ReporterName" class="form-control" placeholder="Enter full name of the reporter" required />
                            <span asp-validation-for="ReporterName" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Police Station Location</label>
                            @if (User.IsInRole("Admin"))
                            {
                                <select asp-for="PoliceStationCode" class="form-select" id="PoliceStationDropdown">
                                    @foreach (var ps in ViewBag.PoliceStations)
                                    {
                                        <option value="@ps.StationCode" data-region="@ps.Region">@ps.StationName</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <input type="text" class="form-control bg-readonly" value="@ViewBag.FixedStationName" readonly />
                                <input type="hidden" asp-for="PoliceStationCode" value="@ViewBag.FixedStationCode" />
                            }
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">District / Region</label>
                            <input type="text" asp-for="Region" id="RegionBox" class="form-control bg-readonly" value="@(User.IsInRole("Admin") ? Model.Region : ViewBag.FixedRegion)" readonly />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Issue" class="form-label">Type of Issue <span class="required-star">*</span></label>
                            <select asp-for="Issue" class="form-select" asp-items="ViewBag.Issues" required id="IssueSelect">
                                <option value="">-- Select Category --</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Priority" class="form-label">Assigned Priority</label>
                            <input asp-for="Priority" class="form-control bg-readonly fw-bold" readonly id="PriorityBox" />
                        </div>

                        <div class="col-12">
                            <label asp-for="Description" class="form-label">Complaint Description <span class="required-star">*</span></label>
                            <textarea asp-for="Description" class="form-control" rows="5" maxlength="500" placeholder="Provide detailed information regarding the issue..." required></textarea>
                            <div class="d-flex justify-content-between mt-1">
                                <span asp-validation-for="Description" class="text-danger small"></span>
                                <small class="text-muted">Max 500 characters</small>
                            </div>
                        </div>

                        <div class="col-12 mt-5">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <a asp-action="ViewUserTicket" asp-route-id="@Model.Id" class="btn btn-cancel w-100">
                                        <i class="bi bi-x-lg me-2"></i> Cancel Edit
                                    </a>
                                </div>
                                <div class="col-md-8">
                                    <button type="submit" class="btn btn-update w-100">
                                        <i class="bi bi-cloud-check-fill me-2"></i> Update Official Record
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>
        $(document).ready(function () {
            const HIGH_ISSUES = ["SERVER INSTALLATION", "RESTORE DB BACKUP", "CHARGESHEET NOT ABLE TO SUBMIT", "FIR NOT ABLE TO SUBMIT", "COMPETENT AUTHORITY WORK TASK 2", "COMPETENT AUTHORITY WORK TASK 1", "REASSIGNING CASES", "ARREST MEMO NOT ABLE TO SUBMIT"];
            const MEDIUM_ISSUES = ["MODIFICATION OF SECTIONS", "CLIENT INSTALLATION", "OFFLINE LOGIN ISSUE", "ONLINE NOT WORKING", "UPDATE WITNESS ADDRESS", "UPDATE COMPLAINANT ADDRESS", "UPDATE ACCUSED AGE", "GD ENTRY", "GD DATE & TIME", "SYNC", "DGsP & IGsP DASHBOARD", "CRIME DETAILS FORM", "ARREST MEMO UNABLE TO ADD WITNESS", "PROPERTY SEIZURE NOT ABLE TO SUBMIT", "FINAL FORM", "VILLAGE CRIME DETAIL FORM", "ADD ACT AND SECTION", "BNS SECTION NOT AVAILABLE", "SHO ISSUE", "ACCUSED AGE CHANGE"];

            function normalize(s) { return (s || "").toString().trim().toUpperCase(); }

            $('#IssueSelect').change(function () {
                const val = normalize($(this).val());
                let priority = "Low";

                if (val === "POCSO") priority = "Urgent";
                else if (HIGH_ISSUES.includes(val)) priority = "High";
                else if (MEDIUM_ISSUES.includes(val)) priority = "Medium";

                $('#PriorityBox').val(priority);

                // Visual feedback for priority
                const pBox = $('#PriorityBox');
                pBox.removeClass('text-danger text-warning text-primary text-info');
                if(priority === 'Urgent' || priority === 'High') pBox.addClass('text-danger');
                else if(priority === 'Medium') pBox.addClass('text-warning');
                else pBox.addClass('text-info');
            });

            if ($('#PoliceStationDropdown').length > 0) {
                $('#PoliceStationDropdown').change(function () {
                    var region = $(this).find(':selected').data('region');
                    $('#RegionBox').val(region);
                });
            }

            // Trigger initial coloring
            $('#IssueSelect').trigger('change');
        });
    </script>
}