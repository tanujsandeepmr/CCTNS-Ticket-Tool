@model List<logindemo.Models.Ticket>
@using System.Web

@{
    ViewData["Title"] = "CCTNS - O&M TEAM";

    // Define the check for your specific users at the top of Index.cshtml
    var currentName = User.Identity?.Name?.ToLower();
    bool isReadOnlyUser = User.Identity.Name == "cctnscell1" || User.Identity.Name == "cctnscell2" || User.Identity.Name == "nodalofficer";


    int total = Model.Count;
    // Include both Open and Re-Opened tickets in the "Open Cases" total count
    int open = Model.Count(t => t.Status == "Open" || t.Status == "Re-Opened");

    // DEFINE THE MISSING VARIABLE HERE
    int pendingPolice = Model.Count(t => t.Status == "Pending from Police Station");

    int completed = Model.Count(t => t.Status == "Completed");

    var statusOrder = new Dictionary<string, int>
    {
        ["Open"] = 4,
        ["Pending from Police Station"] = 3,
        ["Pending"] = 2,
        ["Completed"] = 1,
        ["Closed"] = 0
    };

    var sortedTickets = Model
        .OrderByDescending(t => statusOrder.ContainsKey(t.Status) ? statusOrder[t.Status] : -1)
        .ThenByDescending(t => t.CreatedAt)
        .ToList();
}

@functions {
    public string GetStatusClass(string status)
    {
        return status switch
        {
            "Open" => "danger",
            "Pending from Police Station" => "warning text-dark",
            "Re-Opened" => "danger",
            "Pending" => "secondary",
            "Completed" => "success",
            _ => "info"
        };
    }

    public string GetPriorityClass(string priority)
    {
        return priority switch
        {
            "Urgent" => "dark-red",
            "High" => "danger",
            "Medium" => "primary",
            "Low" => "secondary",
            _ => "secondary"
        };
    }
}

<style>
    /* 1. GLOBAL & LAYOUT VARIABLES */
    :root {
        --navy-blue: #002147;
        --royal-blue: #0056b3;
        --glass-border: rgba(0, 0, 0, 0.08);
        --lite-bg: #f4f7f9;
        --card-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        --hover-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
    }

    body {
        background-color: var(--lite-bg);
        font-family: 'Inter', 'Segoe UI', sans-serif;
        color: #1e293b;
        margin: 0;
        padding: 0;
    }

    /* 2. PREMIUM SUMMARY CARDS ALIGNMENT */
    .premium-card {
        background: #ffffff;
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        position: relative;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        cursor: pointer;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        height: 100%; /* Ensures all cards in a row have equal height */
    }

        .premium-card:hover {
            transform: translateY(-8px);
            box-shadow: var(--hover-shadow);
            border-color: rgba(0, 0, 0, 0.15);
        }

    .glow-bg {
        position: absolute;
        top: -20px;
        right: -20px;
        width: 120px;
        height: 120px;
        border-radius: 50%;
        filter: blur(45px);
        opacity: 0.12;
        z-index: 1;
    }

    .icon-container {
        width: 52px;
        height: 52px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        z-index: 2;
        transition: 0.3s;
    }

    .card-title-text {
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        color: #64748b;
        margin: 1rem 0 0.25rem 0;
        z-index: 2;
    }

    .card-value-text {
        font-size: 2.4rem;
        font-weight: 900;
        margin: 0;
        letter-spacing: -1.5px;
        z-index: 2;
    }

    /* 3. TABLE CONTAINER ALIGNMENT */
    .table-container-glass {
        background: white;
        border-radius: 16px;
        border: 1px solid var(--glass-border);
        box-shadow: var(--card-shadow);
        padding: 1.25rem;
        margin-top: 2rem;
    }

    .table thead th {
        background: var(--navy-blue) !important;
        color: #ffffff !important;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        padding: 18px 12px !important;
        border: none;
        vertical-align: middle;
    }

    .table tbody td {
        padding: 16px 12px !important;
        font-size: 0.92rem;
        font-weight: 500;
        color: #334155;
        vertical-align: middle;
        border-bottom: 1px solid #f1f5f9;
    }

    /* 4. DATA TABLES & SEARCH ALIGNMENT */
    .dataTables_wrapper .dataTables_filter {
        float: right;
        margin-bottom: 1.5rem;
    }

    .dataTables_filter input {
        width: 350px !important;
        height: 46px !important;
        border-radius: 50px !important;
        border: 2px solid #e2e8f0 !important;
        padding: 0 20px 0 50px !important; /* Spacing for the search icon */
        font-weight: 500;
        transition: 0.3s;
    }

        .dataTables_filter input:focus {
            border-color: var(--navy-blue) !important;
            box-shadow: 0 0 0 4px rgba(0, 33, 71, 0.1);
            outline: none;
        }

    /* 5. BADGES & BUTTONS */
    .badge {
        font-size: 0.7rem !important;
        padding: 7px 14px !important;
        border-radius: 50px !important;
        font-weight: 700;
        text-transform: uppercase;
    }

    .bg-dark-red {
        background-color: #991b1b !important;
        color: #fff;
    }

    .btn-action {
        font-size: 0.75rem;
        font-weight: 800;
        padding: 8px 20px;
        border-radius: 50px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        transition: 0.3s;
        border: 2px solid #e2e8f0;
    }

        .btn-action:hover {
            background-color: var(--navy-blue);
            color: white;
            border-color: var(--navy-blue);
        }

    /* 6. COLOR THEMES */
    .theme-total {
        color: var(--navy-blue);
    }

        .theme-total .icon-container {
            background: #f1f5f9;
            color: var(--navy-blue);
        }

        .theme-total .glow-bg {
            background: var(--navy-blue);
        }

    .theme-open {
        color: #be123c;
    }

        .theme-open .icon-container {
            background: #fff1f2;
            color: #be123c;
        }

        .theme-open .glow-bg {
            background: #be123c;
        }

    .theme-pending {
        color: #b45309;
    }

        .theme-pending .icon-container {
            background: #fffbeb;
            color: #b45309;
        }

        .theme-pending .glow-bg {
            background: #b45309;
        }

    .theme-success {
        color: #15803d;
    }

        .theme-success .icon-container {
            background: #f0fdf4;
            color: #15803d;
        }

        .theme-success .glow-bg {
            background: #15803d;
        }


    /* Status Button Effect */
    .btn-status-action {
        transition: all 0.3s ease;
        border: 1px solid transparent;
    }

        .btn-status-action:hover {
            transform: translateY(-2px) scale(1.05);
            box-shadow: 0 4px 8px rgba(0,0,0,0.15);
            filter: brightness(1.1);
            border-color: rgba(255,255,255,0.5);
        }

        .btn-status-action:active {
            transform: translateY(0) scale(0.98);
        }

    /* Pulse for the badge */
    .animate-pulse {
        animation: pulse-red 2s infinite;
    }

    /* Pulse for the "View Reason" button border */
    .animate-pulse-border {
        animation: pulse-border-red 1.5s infinite;
    }

    @@keyframes pulse-red {
        0%

    {
        transform: scale(0.95);
        box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.7);
    }

    70% {
        transform: scale(1);
        box-shadow: 0 0 0 8px rgba(220, 53, 69, 0);
    }

    100% {
        transform: scale(0.95);
        box-shadow: 0 0 0 0 rgba(220, 53, 69, 0);
    }

    }

    @@keyframes pulse-border-red {
        0%

    {
        border-color: #dc3545;
        box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.4);
    }

    70% {
        border-color: transparent;
        box-shadow: 0 0 0 6px rgba(220, 53, 69, 0);
    }

    100% {
        border-color: #dc3545;
        box-shadow: 0 0 0 0 rgba(220, 53, 69, 0);
    }

    }

</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 px-2">
        <h3 class="fw-bold text-navy mb-0">CCTNS - O&M DASHBOARD</h3>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-xl-3 col-md-6" onclick="filterTickets('Total')">
            <div class="premium-card theme-total shadow-sm">
                <div class="glow-bg"></div>
                <div class="icon-container mb-3"><i class="bi bi-stack"></i></div>
                <p class="card-title-text">Total Tickets</p>
                <h2 class="card-value-text">@total</h2>
            </div>
        </div>

        <div class="col-xl-3 col-md-6" onclick="filterTickets('Open')">
            <div class="premium-card theme-open shadow-sm">
                <div class="glow-bg"></div>
                <div class="icon-container mb-3"><i class="bi bi-shield-exclamation"></i></div>
                <p class="card-title-text">Open Cases</p>
                <h2 class="card-value-text">@open</h2>
            </div>
        </div>

        <div class="col-xl-3 col-md-6" onclick="filterTickets('Pending from Police Station')">
            <div class="premium-card theme-pending shadow-sm">
                <div class="glow-bg"></div>
                <div class="icon-container mb-3"><i class="bi bi-hourglass-split"></i></div>
                <p class="card-title-text">Pending from PS</p>
                <h2 class="card-value-text">@pendingPolice</h2>
            </div>
        </div>

        <div class="col-xl-3 col-md-6" onclick="filterTickets('Completed')">
            <div class="premium-card theme-success shadow-sm">
                <div class="glow-bg"></div>
                <div class="icon-container mb-3"><i class="bi bi-check-all"></i></div>
                <p class="card-title-text">Completed</p>
                <h2 class="card-value-text">@completed</h2>
            </div>
        </div>
    </div>

   @*  <br /> *@

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">Ticket Details</h4>
        <div>
            @* FIX: Hide Create button for read-only users *@
            @if (!isReadOnlyUser)
            {
                <a asp-controller="Ticket" asp-action="Create" class="btn btn-success">+ Create New Ticket</a>
            }
        </div>
    </div>


    <div class="table-container-glass">
        <div class="table-responsive">
            <table id="ticketTable" class="table table-hover align-middle text-center mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Police Station</th>
                        <th>Region</th>
                        <th>Reporter</th>
                        <th class="text-start">Issue</th>
                        <th>Created At</th>
                        <th>Completed At</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>User Feedback</th>
                        <th>Ticket Details</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ticket in sortedTickets)
                    {
                        <tr>
                            <td class="fw-bold text-primary">@ticket.TicketId</td>
                            <td>@ticket.PoliceStationName</td>
                            <td>@ticket.Region</td>
                            <td>@ticket.ReporterName</td>
                            <td class="text-start text-truncate" style="max-width: 180px;" title="@ticket.Issue">@ticket.Issue</td>
                            <td style="font-size: 0.75rem;" data-order="@ticket.CreatedAt.ToString("yyyyMMddHHmmss")">
                                <strong>@ticket.CreatedAt.ToString("dd-MM-yy")</strong><br>
                                <span class="text-muted">@ticket.CreatedAt.ToString("hh:mm tt")</span>
                            </td>
                            <td style="font-size: 0.75rem;">
                                @if (ticket.CompletedTime.HasValue)
                                {
                                    <strong>@ticket.CompletedTime.Value.ToString("dd-MM-yy")</strong>
                            
                                    <br>
                                    <span class="text-muted">@ticket.CompletedTime.Value.ToString("hh:mm tt")</span>
                                }
                                else
                                {
                                    <span class="text-muted opacity-50">—</span>
                                }
                            </td>
                            <td>
                                <span class="badge rounded-pill @(ticket.Priority == "Urgent" ? "bg-dark-red" : "bg-" + GetPriorityClass(ticket.Priority))">
                                    @ticket.Priority
                                </span>
                            </td>
                            <td>
                                @if (ticket.Status != "Completed")
                                {
                                    <span class="badge rounded-pill bg-@GetStatusClass(ticket.Status) @(!isReadOnlyUser ? "btn-status-action" : "") @(ticket.Status == "Re-Opened" ? "animate-pulse" : "")"
                                          @(isReadOnlyUser ? "" : "data-bs-toggle=modal data-bs-target=#completeModal")
                                          data-id="@ticket.Id"
                                          data-ticketid="@ticket.TicketId"
                                          data-reporter="@ticket.ReporterName"
                                          data-station="@ticket.PoliceStationName"
                                          data-issue="@ticket.Issue"
                                          data-feedback="@ticket.UserFeedback"
                                          style="@(isReadOnlyUser ? "opacity: 0.8;" : "cursor: pointer;")"
                                          title="@(isReadOnlyUser ? "" : "Click to resolve")">
                                        @ticket.Status
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-success">
                                        <i class="bi bi-check-circle-fill me-1"></i> @ticket.Status
                                    </span>
                                }
                            </td>
                            <td class="text-center">
                                @{
                                    // Step 1: Normalize the string for a safe check
                                    var fb = (ticket.UserFeedback ?? "").Trim().ToLower();

                                    // Step 2: Define what "No Feedback" looks like
                                    bool hasNoRealFeedback = string.IsNullOrWhiteSpace(fb) ||
                                    fb == "not updated" ||
                                    fb == "no not updated";
                                }

                                @if (ticket.Status == "Completed" && !hasNoRealFeedback)
                                {
                                    <button class="btn btn-sm btn-outline-success rounded-pill py-0 px-2 fw-bold shadow-sm"
                                            style="font-size: 0.65rem;"
                                            onclick="showFeedbackPopup('@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(ticket.UserFeedback))', 'success')">
                                        <i class="bi bi-chat-right-heart-fill me-1"></i> FEEDBACK
                                    </button>
                                }
                                else if (ticket.Status == "Re-Opened")
                                {
                                    <button class="btn btn-sm btn-outline-danger rounded-pill py-0 px-2 fw-bold shadow-sm animate-pulse-border"
                                            style="font-size: 0.65rem;"
                                            onclick="showFeedbackPopup('@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(ticket.UserFeedback))', 'danger')">
                                        <i class="bi bi-exclamation-octagon-fill me-1"></i> VIEW REASON
                                    </button>
                                }
                                else
                                {
                                    <div class="d-flex align-items-center justify-content-center text-muted opacity-50" style="font-size: 0.50rem;">
                                        <i class="bi bi-clock-history me-1"></i>
                                        <span class="fw-600">AWAITING FEEDBACK</span>
                                    </div>
                                }
                            </td>

                           @*  <td class="text-center">
                                @if (ticket.Status == "Completed" && !string.IsNullOrEmpty(ticket.UserFeedback))
                                {
                                    <button class="btn btn-sm btn-outline-success rounded-pill py-0 px-2 fw-bold shadow-sm"
                                            style="font-size: 0.65rem;"
                                            onclick="showFeedbackPopup('@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(ticket.UserFeedback))', 'success')">
                                        <i class="bi bi-chat-right-heart-fill me-1"></i> FEEDBACK
                                    </button>
                                }
                                else if (ticket.Status == "Re-Opened")
                                {
                                    <button class="btn btn-sm btn-outline-danger rounded-pill py-0 px-2 fw-bold shadow-sm animate-pulse-border"
                                            style="font-size: 0.65rem;"
                                            onclick="showFeedbackPopup('@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(ticket.UserFeedback))', 'danger')">
                                        <i class="bi bi-exclamation-octagon-fill me-1"></i> VIEW REASON
                                    </button>
                                }
                                else
                                {
                                    <span class="text-muted small italic opacity-50" style="font-size: 0.65rem;">No remarks</span>
                                }
                            </td> *@
                            <td>
                                <div class="d-flex justify-content-center">
                                    <a href="@Url.Action("ViewTicket", "Ticket", new { id = ticket.Id })"
                                       class="btn btn-sm btn-outline-primary px-3 rounded-pill"
                                       style="font-size: 0.7rem; font-weight: 700;">
                                        VIEW
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="modal fade" id="completeModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="border-radius: 15px;">
                <form id="completeForm" method="post" action="@Url.Action("MarkAsCompleted", "Ticket")">
                    @Html.AntiForgeryToken()
                    <div id="modalHeader" class="modal-header border-0 bg-success text-white py-3" style="border-radius: 15px 15px 0 0;">
                        <h5 class="modal-title fw-bold">
                            <i class="bi bi-check-circle-fill me-2"></i> Verify Completion
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body p-4">
                        <input type="hidden" name="id" id="modalTicketDbId" />

                        <div id="reopenedFeedbackSection" class="mb-4" style="display:none;">
                            <div class="alert alert-danger border-0 shadow-sm d-flex align-items-start" style="border-radius: 12px; background-color: #fff5f5;">
                                <i class="bi bi-chat-left-text-fill text-danger fs-4 me-3 mt-1"></i>
                                <div>
                                    <div class="text-danger small fw-bold text-uppercase">User Remarks</div>
                                    <div id="modalUserFeedback" class="text-dark fw-bold mt-1">---</div>
                                </div>
                            </div>
                        </div>

                        <div class="bg-light p-3 rounded-3 mb-4 border shadow-sm">
                            <div class="row g-2">
                                <div class="col-4 text-muted small fw-bold">TICKET ID</div>
                                <div class="col-8 fw-bold text-primary" id="modalTicketId">---</div>
                                <div class="col-4 text-muted small fw-bold">STATION</div>
                                <div class="col-8 fw-600" id="modalStation">---</div>
                            </div>
                        </div>
                        <p class="text-center fw-bold">Mark this issue as resolved?</p>
                    </div>
                    <div class="modal-footer border-0 pb-4 d-flex justify-content-center">
                        <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Discard</button>
                        <button type="submit" class="btn btn-success rounded-pill px-4 fw-bold shadow-sm">Confirm Resolution</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

        <script>
            $(document).ready(function () {
                // 1. Initialize DataTable
                const table = $('#ticketTable').DataTable({
                    pageLength: 20,
                    lengthChange: false,
                    searching: true,
                    order: [[5, 'desc']],
                    language: {
                        paginate: { previous: "Prev", next: "Next" },
                        search: "",
                        searchPlaceholder: "Search ID, Station, or Issue..."
                    },
                    dom: '<"d-flex justify-content-between align-items-center mb-3"f>rt<"d-flex justify-content-between align-items-center mt-3"ip>',
                    drawCallback: function() {
                        $('.dataTables_filter input')
                            .addClass('form-control shadow-sm rounded-pill px-4')
                            .css({ "width": "400px", "height": "46px", "border": "2px solid #e0e0e0" });
                    }
                });

                window.tableInstance = table;

                // 2. Dashboard Card Filtering
                window.filterTickets = function (status) {
                    if (!window.tableInstance) return;

                    // Clear all existing filters
                    window.tableInstance.search('').columns().search('');

                    if (status === "Total") {
                        window.tableInstance.draw();
                    }
                    else if (status === "Open") {
                        window.tableInstance.column(8).search('Open|Re-Opened', true, false).draw();
                    }
                    else if (status === "Pending from Police Station") {
                        // Broad search for 'Pending' to catch the full phrase
                        window.tableInstance.column(8).search('Pending', false, true).draw();
                    }
                    else if (status === "Completed") {
                        window.tableInstance.column(8).search('Completed', false, true).draw();
                    }
                };

                // 3. Feedback Popup
                window.showFeedbackPopup = function(message, type) {
                    const isSuccess = type === 'success';
                    const displayMessage = (message && message !== 'null' && message !== '') ? message : 'No specific comments provided.';
                    Swal.fire({
                        title: isSuccess ? '<span class="text-success">User Satisfaction</span>' : '<span class="text-danger">Issue Not Resolved</span>',
                        html: `<div class="p-3 bg-light rounded shadow-inner text-dark fw-bold" style="border-left: 4px solid ${isSuccess ? '#198754' : '#dc3545'}">"${displayMessage}"</div>`,
                        icon: isSuccess ? 'success' : 'warning',
                        confirmButtonText: 'Close',
                        confirmButtonColor: isSuccess ? '#198754' : '#dc3545'
                    });
                };

                // 4. Modal Data Population (Fixes data mapping)
                $(document).on('show.bs.modal', '#completeModal', function (event) {
                    const button = $(event.relatedTarget);
                    // Ensure these match the 'data-' attributes in your <span> badge
                    $('#modalTicketDbId').val(button.data('id'));
                    $('#modalTicketId').text(button.data('ticketid'));
                    $('#modalStation').text(button.data('station'));

                    // Handle Feedback display in modal if it's a re-opened ticket
                    const feedback = button.data('feedback');
                    if (feedback) {
                        $('#modalUserFeedback').text(feedback);
                        $('#reopenedFeedbackSection').show();
                    } else {
                        $('#reopenedFeedbackSection').hide();
                    }
                });

                // 5. AJAX Submission (Unified to point to the correct Action)
               $('#completeForm').on('submit', function(e) {
    e.preventDefault();
    
    const form = $(this);
    const submitBtn = form.find('button[type="submit"]');
    submitBtn.prop('disabled', true).text('Processing...');

    $.ajax({
        url: form.attr('action'), 
        type: 'POST',
        data: form.serialize(), // Changed from FormData to serialize()
        success: function(response) {
            Swal.fire({
                icon: 'success',
                title: 'Resolved!',
                text: response.message,
                timer: 1500,
                showConfirmButton: false
            }).then(() => {
                location.reload();
            });
        },
        error: function(xhr) {
            console.error(xhr.responseText); // This helps you debug in F12
            Swal.fire('Error', 'Could not update ticket status.', 'error');
            submitBtn.prop('disabled', false).text('Confirm Resolution');
        }
    });
});
            });
        </script>
}