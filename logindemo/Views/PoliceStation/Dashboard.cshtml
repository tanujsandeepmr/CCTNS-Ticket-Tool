@inject Microsoft.AspNetCore.Mvc.Rendering.IHtmlHelper<dynamic> HtmlHelper
@model logindemo.Models.PoliceStation

@{
    var isIdentityPage = HtmlHelper.ViewContext.RouteData.Values["Area"]?.ToString() == "Identity";
    var currentPage = HtmlHelper.ViewContext.RouteData.Values["Page"]?.ToString()?.ToLower();
    var hideSidebar = isIdentityPage && (currentPage == "/account/login");

    ViewData["Title"] = "Police Station Dashboard";
    bool isDataIncomplete = string.IsNullOrEmpty(Model?.Location) ||
                            string.IsNullOrEmpty(Model?.StationCode) ||
                            string.IsNullOrEmpty(Model?.Region) ||
                            string.IsNullOrEmpty(Model?.ContactNumber) ||
                            string.IsNullOrEmpty(Model?.IPAddress) ||
                            string.IsNullOrEmpty(Model?.Incharge);
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

<style>
    .dashboard-container {
        display: flex;
        flex-direction: row;
        min-height: 100vh;
        background-color: #f8f9fa;
    }

    .sidebar {
        width: 250px;
        background: #2c3e50;
        padding: 20px;
        color: white;
        position: fixed;
        height: 100vh;
    }

        .sidebar h3 {
            margin-bottom: 20px;
        }

        .sidebar a {
            display: block;
            padding: 10px 15px;
            color: white;
            text-decoration: none;
            border-radius: 8px;
            margin-bottom: 8px;
            font-weight: 500;
            transition: all 0.2s ease;
        }

            .sidebar a:hover {
                background-color: #34495e;
            }

    .main-content {
        margin-left: 250px;
        padding: 30px;
        flex-grow: 1;
    }

    .card-box {
        padding: 20px;
        border-radius: 15px;
        text-align: center;
        font-size: 18px;
        font-weight: bold;
        color: white;
        min-width: 220px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        transition: transform 0.3s ease-in-out;
    }

        .card-box:hover {
            transform: translateY(-5px);
        }

    .total-tickets {
        background: linear-gradient(to right, #007bff, #00c6ff);
    }

    .open-tickets {
        background: linear-gradient(to right, #f39c12, #f1c40f);
    }

    .pending-tickets {
        background: linear-gradient(to right, #ff9800, #ff5722);
    }

    .closed-tickets {
        background: linear-gradient(to right, #28a745, #218838);
    }

    th {
        background-color: #007bff;
        color: white;
    }

    .table td, .table th {
        vertical-align: middle;
    }

    tr:hover {
        background-color: rgba(0, 123, 255, 0.1);
    }
</style>

<div class="dashboard-container">
    <!-- Sidebar -->
    <aside class="sidebar" aria-label="Sidebar Navigation">
        <h3><i class="bi bi-shield-lock-fill me-2"></i>Police Panel</h3>
        <a href="#"><i class="bi bi-house-door-fill me-2"></i>Dashboard</a>
        <a href="#"><i class="bi bi-folder-fill me-2"></i>Police Records</a>
        <a href="#"><i class="bi bi-ticket-perforated-fill me-2"></i>Assigned Tickets</a>
        <a href="#"><i class="bi bi-clipboard-data-fill me-2"></i>Crime Reports</a>
        <a href="#"><i class="bi bi-gear-fill me-2"></i>Settings</a>
        <a href="/Account/Logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <h2 class="mb-4 fw-bold text-primary">Welcome, @(Model?.StationName ?? "Station")</h2>

        <!-- Stats Cards -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card-box total-tickets">
                    <i class="bi bi-journal-text fs-2"></i><br />
                    Total Tickets<br />
                    <span class="fs-4">@((Model?.Tickets?.Count() ?? 0))</span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card-box open-tickets">
                    <i class="bi bi-folder2-open fs-2"></i><br />
                    Open<br />
                    <span class="fs-4">@((Model?.Tickets?.Count(t => t.Status == "Open") ?? 0))</span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card-box pending-tickets">
                    <i class="bi bi-hourglass-split fs-2"></i><br />
                    Pending<br />
                    <span class="fs-4">@((Model?.Tickets?.Count(t => t.Status == "Pending") ?? 0))</span>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card-box closed-tickets">
                    <i class="bi bi-check-circle-fill fs-2"></i><br />
                    Closed<br />
                    <span class="fs-4">@((Model?.Tickets?.Count(t => t.Status == "Closed") ?? 0))</span>
                </div>
            </div>
        </div>

        <!-- Station Info -->
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white fw-bold">Station Information</div>
            <div class="card-body">
                <table class="table table-bordered mb-0">
                    <tr><th>Name</th><td>@(Model?.StationName ?? "-")</td></tr>
                    <tr><th>Location</th><td>@(Model?.Location ?? "-")</td></tr>
                    <tr><th>Code</th><td>@(Model?.StationCode ?? "-")</td></tr>
                    <tr><th>Contact</th><td>@(Model?.ContactNumber ?? "-")</td></tr>
                </table>
            </div>
        </div>

        <!-- Ticket Table -->
        <h4 class="mb-3">Tickets Assigned</h4>
        <div class="table-responsive shadow-sm rounded bg-white p-3">
            <table class="table table-striped table-hover align-middle">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Reporter</th>
                        <th>Issue</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Priority</th>
                        <th>Completed Time</th> <!-- ✅ Added -->
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model?.Tickets != null && Model.Tickets.Any())
                    {
                        foreach (var ticket in Model.Tickets)
                        {
                            var badgeClass = ticket.Status switch
                            {
                                "Open" => "bg-primary",
                                "Pending" => "bg-warning text-dark",
                                "Closed" => "bg-success",
                                "Completed" => "bg-success",
                                _ => "bg-secondary"
                            };

                            var priorityClass = ticket.Priority switch
                            {
                                "High" => "bg-danger",
                                "Medium" => "bg-warning text-dark",
                                "Low" => "bg-info text-dark",
                                _ => "bg-secondary"
                            };
                            <tr>
                                <td>@ticket.TicketId</td>
                                <td>@ticket.ReporterName</td>
                                <td>@ticket.Issue</td>
                                <td>@ticket.Description</td>
                                <td><span class="badge @badgeClass">@ticket.Status</span></td>
                                <td><span class="badge @priorityClass">@ticket.Priority</span></td>
                                <td>
                                    @if (ticket.CompletedTime.HasValue)
                                    {
                                        @ticket.CompletedTime?.ToString("dd-MM-yyyy HH:mm")
                                    }
                                    else
                                    {
                                        <span class="text-muted">--</span>
                                    }
                                </td>
                                <td>
                                    <button class="btn btn-outline-primary btn-sm view-ticket-btn" data-id="@ticket.Id"><i class="bi bi-eye"></i></button>
                                    <button class="btn btn-outline-success btn-sm" onclick="markCompleted('@ticket.Id')"><i class="bi bi-check2-square"></i></button>
                                    <button class="btn btn-outline-danger btn-sm" onclick="reopenTicket('@ticket.Id')"><i class="bi bi-arrow-counterclockwise"></i></button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center">No tickets available.</td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>
    </main>
</div>

<!-- View Modal -->
<div class="modal fade" id="viewTicketModal" tabindex="-1" aria-labelledby="viewTicketModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Ticket Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="ticketModalBody">
                <!-- AJAX-loaded content -->
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.querySelectorAll(".view-ticket-btn").forEach(button => {
            button.addEventListener("click", function () {
                const ticketId = this.getAttribute("data-id");
                fetch(`/Ticket/ViewTicketPartial/${ticketId}`)
                    .then(response => response.text())
                    .then(html => {
                        document.getElementById("ticketModalBody").innerHTML = html;
                        new bootstrap.Modal(document.getElementById("viewTicketModal")).show();
                    });
            });
        });

        function markCompleted(ticketId, completedBy) {
            if (confirm("Mark this ticket as completed?")) {
                fetch("/Ticket/MarkAsCompleted", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "RequestVerificationToken": document.querySelector('input[name="__RequestVerificationToken"]')?.value || ""
                    },
                    body: JSON.stringify({ ticketId, completedBy })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        alert(data.message);
                        location.reload(); // Refresh the dashboard
                    } else {
                        alert("Failed to complete ticket.");
                    }
                })
                .catch(error => {
                    console.error("Error:", error);
                    alert("An error occurred.");
                });
            }
        }

        function reopenTicket(id) {
            if (confirm("Reopen this ticket?")) {
                window.location.href = `/Ticket/Reopen/${id}`;
            }
        }
    </script>
}
